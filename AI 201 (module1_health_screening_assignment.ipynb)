    {
      "cell_type": "code",
      "source": [
        "print(\"--- Task 3: Creating Health Indicators ---\")\n",
        "\n",
        "# User-defined function to calculate BMI Category\n",
        "def get_bmi_category(bmi):\n",
        "    if bmi < 18.5:\n",
        "        return 'Underweight'\n",
        "    elif 18.5 <= bmi < 25.0:\n",
        "        return 'Normal'\n",
        "    elif 25.0 <= bmi < 30.0:\n",
        "        return 'Overweight'\n",
        "    else:\n",
        "        return 'Obese'"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "a2CtRLMJMlkV",
        "outputId": "9c72d32d-ddcf-44f8-d308-d859425d0928"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "--- Task 3: Creating Health Indicators ---\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# User-defined function to determine Blood Pressure Category\n",
        "def get_bp_category(row):\n",
        "    sys = row['Systolic Blood Pressure']\n",
        "    dia = row['Diastolic Blood Pressure']\n",
        "    if sys < 120 and dia < 80:\n",
        "        return 'Normal'\n",
        "    elif 120 <= sys <= 129 and dia < 80:\n",
        "        return 'Elevated'\n",
        "    elif 130 <= sys <= 139 or 80 <= dia <= 89:\n",
        "        return 'Hypertension Stage 1'\n",
        "    else:\n",
        "        return 'Hypertension Stage 2'"
      ],
      "metadata": {
        "id": "3agy65r1M3K_"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "\n",
        "# User-defined function to assess Overall Health Risk Level\n",
        "def get_health_risk(row):\n",
        "    risk_points = 0\n",
        "\n",
        "    # Check BMI risk\n",
        "    if row['BMI Category'] in ['Overweight', 'Obese']:\n",
        "        risk_points += 1\n",
        "\n",
        "    # Check Blood Pressure risk\n",
        "    if 'Hypertension' in row['BP Category']:\n",
        "        risk_points += 1\n",
        "\n",
        "    # Check High Blood Sugar risk (Prediabetes/Diabetes threshold generally 100+ mg/dL)\n",
        "    if row['Blood Sugar Level (mg/dL)'] >= 100:\n",
        "        risk_points += 1\n",
        "         # Check Smoking Risk\n",
        "    if row['Smoking Status'] == 'Yes':\n",
        "        risk_points += 1\n",
        "\n",
        "    # Map points to risk profiles\n",
        "    if risk_points <= 1:\n",
        "        return 'Low Risk'\n",
        "    elif risk_points == 2:\n",
        "        return 'Moderate Risk'\n",
        "    else:\n",
        "        return 'High Risk'\n",
        "\n"
      ],
      "metadata": {
        "id": "uvUXRixAM7VX"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Calculate BMI column dynamically: Weight (kg) / (Height (m)^2)\n",
        "df['BMI'] = df['Weight (kg)'] / ((df['Height (cm)'] / 100) ** 2)\n",
        "\n",
        "# Apply category functions to the DataFrame\n",
        "df['BMI Category'] = df['BMI'].apply(get_bmi_category)\n",
        "df['BP Category'] = df.apply(get_bp_category, axis=1)\n",
        "df['Overall Health Risk'] = df.apply(get_health_risk, axis=1)\n",
        "\n",
        "print(\"Processed dataset with newly computed health features:\")\n",
        "print(df[['Patient ID', 'BMI', 'BMI Category', 'BP Category', 'Overall Health Risk']].head())\n",
        "print(\"\\n\" + \"=\"*50 + \"\\n\")\n"
